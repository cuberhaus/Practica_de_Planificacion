# OpenTelemetry boot configuration for `npm run dev:obs`.
# Copy to `.env.obs` (gitignored) and edit if needed.
#
# When OTEL_EXPORTER_OTLP_ENDPOINT is set, src/instrument.ts brings up
# the OTel NodeSDK; when it isn't, instrument.ts is a no-op and the app
# behaves like a stock SvelteKit dev server.
#
# These env vars are loaded by Node via the `--env-file` flag (added in
# Node 20.6 / always-on in Node 22+) — no `dotenv` package needed.

# Where to ship traces / metrics / logs. Points at the Phase-1 OTel
# Collector running on the host. For a remote Grafana Cloud / Loki tenant,
# swap to that endpoint; the SDK speaks OTLP gRPC the same either way.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Resource attributes attached to every signal. The SDK reads these in
# addition to anything we set programmatically in instrument.ts —
# `deployment.environment.name` here is what the Phase-4 dashboards
# filter on.
OTEL_RESOURCE_ATTRIBUTES=deployment.environment.name=local-dev

# Sampling. `parentbased_traceidratio` honours an upstream sampling
# decision (e.g. from a future Faro browser RUM trace) and falls back to
# the ratio for root spans. 1.0 is fine on a local box; production
# should drop to 0.1 to keep storage bounded.
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# Exporter selection — keeps both metrics and logs flowing through OTLP
# so the SDK's batch processors do their thing. `none` disables a signal
# entirely (useful when the collector is reachable but a backend isn't).
OTEL_LOGS_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp

# Identity bookkeeping. service.name and service.namespace are set in
# instrument.ts; service.version comes from this file via GIT_SHA so a
# `release` filter shows up cleanly in Grafana. CI should `export
# GIT_SHA=$(git rev-parse --short HEAD)` before building.
GIT_SHA=dev

# Pino logger verbosity. `info` in dev keeps the stack chatty enough to
# spot issues; `warn` is a reasonable production default.
LOG_LEVEL=info
