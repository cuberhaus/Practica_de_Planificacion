# Copy to `.env.obs` and customise. Loaded by docker compose via:
#   docker compose -f docker-compose.obs.yml --env-file .env.obs up -d
#
# Two profiles below: local MinIO (default, uncommented) and Hetzner Object
# Storage (commented). Pick one — `S3_ENDPOINT` is the only field that
# decides which backend everything writes to.

# ── Local MinIO (default) ──────────────────────────────────────────
# Internal address: the in-network MinIO container is reachable as
# `minio:9000`. The host can also browse it at http://localhost:9001
# for the bucket UI.
S3_ENDPOINT=minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=obsadmin
S3_SECRET_KEY=obsadmin123
S3_INSECURE=true

# ── Hetzner Object Storage (VPS profile) ───────────────────────────
# Uncomment the block and comment out the MinIO block above to flip the
# entire stack onto Hetzner without touching any of the .yaml files.
# Requires the `minio-init` container be skipped (the buckets are pre-
# created in the Hetzner console).
#
# S3_ENDPOINT=nbg1.your-objectstorage.com
# S3_REGION=nbg1
# S3_ACCESS_KEY=<from Hetzner console>
# S3_SECRET_KEY=<from Hetzner console>
# S3_INSECURE=false

# ── Generic AWS S3 / Backblaze B2 / etc. ───────────────────────────
# S3_ENDPOINT=s3.eu-central-1.amazonaws.com
# S3_REGION=eu-central-1
# S3_ACCESS_KEY=AKIA...
# S3_SECRET_KEY=...
# S3_INSECURE=false
